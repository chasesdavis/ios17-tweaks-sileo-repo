<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Injecting on com.apple.UIKit lands the dylib in every UIKit process:
	  normal apps (per-app lock) AND SpringBoard (app hiding). We branch by
	  process at load time in %ctor.
	-->
	<key>Filter</key>
	<dict>
		<key>Bundles</key>
		<array>
			<string>com.apple.UIKit</string>
		</array>
	</dict>
</dict>
</plist>
