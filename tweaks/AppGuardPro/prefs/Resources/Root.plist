<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>AppGuard Pro</string>
			<key>footerText</key>
			<string>Lock apps behind Face ID / passcode, hide apps from the Home Screen, and optionally fake a crash after repeated failed unlocks.</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>label</key>
			<string>Enabled</string>
			<key>key</key>
			<string>enabled</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.chasedavis.appguardpro</string>
			<key>PostNotification</key>
			<string>com.chasedavis.appguardpro/reload</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>App Lock</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>label</key>
			<string>Use Biometrics</string>
			<key>key</key>
			<string>useBiometrics</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.chasedavis.appguardpro</string>
			<key>PostNotification</key>
			<string>com.chasedavis.appguardpro/reload</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkCell</string>
			<key>label</key>
			<string>Choose Locked Apps</string>
			<key>detail</key>
			<string>AGPAppListController</string>
			<key>isController</key>
			<true/>
			<key>mode</key>
			<string>lock</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Hidden Apps</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkCell</string>
			<key>label</key>
			<string>Choose Hidden Apps</string>
			<key>detail</key>
			<string>AGPAppListController</string>
			<key>isController</key>
			<true/>
			<key>mode</key>
			<string>hide</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Fake-Crash Decoy (Pro)</string>
			<key>footerText</key>
			<string>After the chosen number of failed or cancelled unlocks, the locked app instantly quits so it looks like it crashed.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>label</key>
			<string>Enable Decoy</string>
			<key>key</key>
			<string>decoyEnabled</string>
			<key>default</key>
			<false/>
			<key>defaults</key>
			<string>com.chasedavis.appguardpro</string>
			<key>PostNotification</key>
			<string>com.chasedavis.appguardpro/reload</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSegmentCell</string>
			<key>label</key>
			<string>Attempts</string>
			<key>key</key>
			<string>decoyThreshold</string>
			<key>default</key>
			<integer>3</integer>
			<key>defaults</key>
			<string>com.chasedavis.appguardpro</string>
			<key>PostNotification</key>
			<string>com.chasedavis.appguardpro/reload</string>
			<key>validTitles</key>
			<array>
				<string>1</string>
				<string>2</string>
				<string>3</string>
				<string>5</string>
			</array>
			<key>validValues</key>
			<array>
				<integer>1</integer>
				<integer>2</integer>
				<integer>3</integer>
				<integer>5</integer>
			</array>
		</dict>
	</array>
	<key>title</key>
	<string>AppGuard Pro</string>
</dict>
</plist>
